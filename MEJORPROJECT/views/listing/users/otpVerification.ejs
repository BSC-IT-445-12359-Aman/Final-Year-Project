<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OTP Verification</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .otp-container {
            background: white;
            padding: 2rem;
            border-radius: 15px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            max-width: 400px;
            width: 100%;
        }
        .otp-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(45deg, #667eea, #764ba2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            font-size: 2rem;
            color: white;
        }
        .otp-input {
            font-size: 1.5rem;
            text-align: center;
            letter-spacing: 0.5rem;
            font-weight: bold;
        }
        .otp-input:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
        }
        .btn-verify {
            background: linear-gradient(45deg, #667eea, #764ba2);
            border: none;
            padding: 0.75rem;
            font-weight: 600;
            transition: transform 0.2s;
        }
        .btn-verify:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
        .countdown {
            color: #6c757d;
            font-size: 0.9rem;
        }
        .resend-link {
            color: #667eea;
            text-decoration: none;
            font-weight: 600;
        }
        .resend-link:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="otp-container">
            <div class="text-center mb-4">
                <div class="otp-icon">
                    <i class="fas fa-shield-alt"></i>
                </div>
                <h2 class="mb-3">OTP Verification</h2>
                <p class="text-muted">
                    Enter the 6-digit code sent to:<br>
                    <strong><%= email %></strong>
                </p>
            </div>
            
            <% if (typeof emailFailed !== 'undefined' && emailFailed) { %>
                <div class="alert alert-warning" role="alert">
                    <strong>⚠️ Email service unavailable</strong><br>
                    Use this OTP: <span class="badge bg-danger fs-5"><%= debugOTP %></span>
                </div>
            <% } %>
            
            <% if (error && error.length > 0) { %>
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <%= error %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>
            
            <% if (success && success.length > 0) { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <%= success %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>

            <form action="/admin/verify-otp" method="POST">
                <div class="mb-3">
                    <label for="otp" class="form-label">Enter OTP</label>
                    <input type="text" class="form-control otp-input" id="otp" name="otp" 
                           maxlength="6" pattern="[0-9]{6}" required 
                           placeholder="000000" autocomplete="one-time-code">
                </div>
                
                <div class="text-center mb-3">
                    <small class="countdown">OTP expires in 10 minutes</small>
                </div>
                
                <div class="d-grid mb-3">
                    <button type="submit" class="btn btn-primary btn-verify">
                        Verify OTP
                    </button>
                </div>
                
                <div class="text-center">
                    <small>Didn't receive the code? </small>
                    <a href="/admin/login" class="resend-link">Resend OTP</a>
                </div>
            </form>
            
            <div class="text-center mt-3">
                <a href="/admin/login" class="text-decoration-none">
                    <i class="fas fa-arrow-left"></i> Back to Login
                </a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <script>
        // Auto-format OTP input
        document.getElementById('otp').addEventListener('input', function(e) {
            this.value = this.value.replace(/[^0-9]/g, '').slice(0, 6);
        });
    </script>
</body>
</html>
